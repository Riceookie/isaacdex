{
  "name": "isaacdex",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "description": "IsaacDex — companion do The Binding of Isaac: achievementy (Steam), completion marks, doradca itemów (monorepo)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "secretlint": "secretlint \"**/*\"",
    "dupcheck": "jscpd .",
    "start:api": "pnpm --filter @isaacdex/api start",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mjs,cjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*": [
      "secretlint"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "@secretlint/secretlint-rule-preset-recommend": "^9.0.0",
    "globals": "^15.12.0",
    "husky": "^9.1.0",
    "jscpd": "^4.0.5",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "secretlint": "^9.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.15.0"
  }
}
