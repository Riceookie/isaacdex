# Środowisko aplikacji web (Next.js). Skopiuj do .env.local i uzupełnij.
# .env*.local jest w .gitignore — sekretów NIE commitujemy.

# Baza (Prisma) — ten sam Postgres co reszta projektu.
DATABASE_URL=""
DIRECT_URL=""

# Steam Web API — persona i achievementy. Bez klucza logowanie przez Steam nadal działa,
# tylko nick świeżego konta leci z fallbacku (Gracz<last4>), a achievementów nie dociągamy.
STEAM_API_KEY=""

# Supabase Auth (konta). Anon key MUSI być w formacie JWT (eyJ…) — Realtime (czat) nie
# działa z kluczem sb_publishable_.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# service_role (SERWER, nigdy NEXT_PUBLIC — to klucz-wytrych do całego projektu).
# Potrzebny do jednej rzeczy: „Zaloguj się przez Steam" wchodzące na ISTNIEJĄCE konto
# e-mail/hasło z ręcznie podpiętym Steamem (mintujemy mu sesję jednorazowym magic-linkiem).
# Bez niego reszta logowania działa; nie udaje się tylko ten jeden przypadek.
SUPABASE_SERVICE_ROLE_KEY=""
