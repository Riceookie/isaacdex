# Połączenie do PostgreSQL (Supabase → Project Settings → Database → Connection string).
#
# DATABASE_URL — połączenie przez POOLER (port 6543), używane przez aplikację w runtime.
#   Dopisz na końcu ?pgbouncer=true
# DIRECT_URL — połączenie BEZPOŚREDNIE (port 5432), używane przez migracje Prisma.
#
# Skopiuj ten plik do .env i wstaw prawdziwe wartości (hasło bazy z Supabase):

DATABASE_URL="postgresql://postgres.<ref>:<HASLO>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<HASLO>@aws-0-<region>.pooler.supabase.com:5432/postgres"
