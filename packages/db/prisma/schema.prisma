// Schemat bazy IsaacDex — companion do The Binding of Isaac.
// Encje ze specyfikacji (docs/specyfikacja.md). Baza: PostgreSQL.

generator client {
  provider      = "prisma-client-js"
  // "native" do lokalnego dev; "rhel-openssl-3.0.x" dla runtime Vercela (AWS Lambda).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Użytkownik / profil (jego dane spięte z kontem Steam) ──────────────────────

model Profil {
  id             Int       @id @default(autoincrement())
  steamId64      String    @unique
  nick           String?
  opis           String?
  ulubionaPostac String?
  ostatniSync    DateTime?
  createdAt      DateTime  @default(now())

  achievementy    SteamAchievement[]
  completionMarks CompletionMark[]
  /// Gracz, który podpiął ten Steam (strona odwrotna do Gracz.profil).
  gracz           Gracz?
}

// ── Achievementy Steam (zsynchronizowane z Web API) ────────────────────────────

model SteamAchievement {
  id               Int       @id @default(autoincrement())
  apiName          String // "apiname" ze Steama
  nazwa            String
  opis             String?
  ikonaUrl         String?
  globalnyProcent  Decimal?  @db.Decimal(5, 2) // jak rzadki (globalny %)
  odblokowany      Boolean   @default(false)
  dataOdblokowania DateTime?

  profil   Profil @relation(fields: [profilId], references: [id], onDelete: Cascade)
  profilId Int

  @@unique([profilId, apiName])
  @@index([odblokowany])
}

// ── Postacie i completion marks (ekran save file, uzupełniane ręcznie) ──────────

model Postac {
  id        Int              @id @default(autoincrement())
  nazwa     String           @unique
  kolejnosc Int              @default(0)
  marks     CompletionMark[]
}

model CompletionMark {
  id        Int         @id @default(autoincrement())
  boss      BossKoncowy
  tryb      TrybGry
  zaliczone Boolean     @default(false)
  data      DateTime?

  postac   Postac @relation(fields: [postacId], references: [id], onDelete: Cascade)
  postacId Int
  profil   Profil @relation(fields: [profilId], references: [id], onDelete: Cascade)
  profilId Int

  @@unique([profilId, postacId, boss, tryb])
  @@index([postacId])
}

// ── Katalog itemów + doradca "brać/zostawić" ───────────────────────────────────

model Item {
  id       Int       @id @default(autoincrement())
  idW      Int? // id kolekcjonerskie z gry (collectible id)
  nazwa    String    @unique
  jakosc   Int // 0–4
  typ      TypItemu  @default(PASYWNY)
  opis     String?
  ikonaUrl String?
  tagi     String[] // np. ["dmg up", "tears up"]
  runItemy RunItem[]

  @@index([jakosc])
}

// ── Log runów (opcjonalnie / rozwinięcie w zadaniu 8) ──────────────────────────

model Run {
  id      Int          @id @default(autoincrement())
  postac  String
  boss    BossKoncowy?
  wynik   WynikRunu    @default(LOSS)
  czasMin Int?
  seed    String?
  notatka String?
  data    DateTime     @default(now())

  itemy RunItem[]
}

model RunItem {
  run    Run  @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId  Int
  item   Item @relation(fields: [itemId], references: [id])
  itemId Int

  @@id([runId, itemId])
  @@index([itemId])
}

// ── Enumy ──────────────────────────────────────────────────────────────────────

enum TrybGry {
  NORMAL
  HARD
}

enum WynikRunu {
  WIN
  LOSS
}

enum TypItemu {
  PASYWNY
  AKTYWNY
  TRINKET
}

enum BossKoncowy {
  MOMS_HEART
  ISAAC
  SATAN
  BLUE_BABY
  LAMB
  MEGA_SATAN
  BOSS_RUSH
  HUSH
  DELIRIUM
  MOTHER
  BEAST
}

// ── Społeczność: gracze, obserwowanie, feed ───────────────────────────────────
// Gracz to profil społecznościowy. Może być:
//  - PRAWDZIWY  — spięty z kontem Supabase Auth przez `userId`,
//  - DEMO       — zasiany, bez konta (żeby feed i czat nie były puste),
//  - WŁAŚCICIEL — `ja = true`: gracz pokazywany gościom, którzy nie są zalogowani.
//    Dzięki temu apka ma co pokazać bez logowania, a konto tylko PRZEJMUJE tę tożsamość.
//
// Steam podpina się osobno (`profil`): dopiero on daje achievementy i % ukończenia,
// więc można mieć konto bez Steama i Steam bez konta (dane zsyncowane wcześniej).

model Gracz {
  id     Int     @id @default(autoincrement())
  nick   String  @unique
  kolor  String? // kolor nicku w feedzie (jak role-color na Discordzie)
  opis   String?
  avatar String? // ikona postaci TBOI (np. „Isaac")
  ja     Boolean @default(false) // gracz pokazywany niezalogowanym gościom

  /// id użytkownika z Supabase Auth (auth.users.id). Null = gracz demo, bez konta.
  userId String? @unique

  /// Podpięte konto Steam (achievementy, completion marks). Null = Steam niepodpięty.
  profil   Profil? @relation(fields: [profilId], references: [id])
  profilId Int?    @unique

  wpisy       Wpis[]
  lajki       Lajk[]
  obserwuje   Obserwacja[] @relation("obserwujacy")
  obserwowany Obserwacja[] @relation("obserwowany")
}

model Obserwacja {
  obserwujacy   Gracz @relation("obserwujacy", fields: [obserwujacyId], references: [id], onDelete: Cascade)
  obserwujacyId Int
  obserwowany   Gracz @relation("obserwowany", fields: [obserwowanyId], references: [id], onDelete: Cascade)
  obserwowanyId Int

  createdAt DateTime @default(now())

  @@id([obserwujacyId, obserwowanyId])
  @@index([obserwowanyId])
}

model Wpis {
  id       Int     @id @default(autoincrement())
  autor    Gracz   @relation(fields: [autorId], references: [id], onDelete: Cascade)
  autorId  Int
  typ      TypWpisu
  tresc    String // np. nazwa achievementu, bossa albo opis runu
  postac   String? // którą postacią
  ikonaUrl String? // ikona achievementu ze Steama (prawdziwa)
  itemy    String[] // itemy z runu (nazwy)

  createdAt DateTime @default(now())
  lajki     Lajk[]

  @@index([createdAt])
  @@index([autorId])
}

model Lajk {
  wpis    Wpis  @relation(fields: [wpisId], references: [id], onDelete: Cascade)
  wpisId  Int
  gracz   Gracz @relation(fields: [graczId], references: [id], onDelete: Cascade)
  graczId Int

  @@id([wpisId, graczId])
}

enum TypWpisu {
  UNLOCK // odblokowany achievement
  BOSS // pokonany boss
  RUN // zakończony run
  TEKST // zwykły wpis
}
